cpu_test() {
    if(!this.cpuperf) {
        this.cpuperf = perf_stat();
        if(!this.cpuperf.start()) {
            console.println("spssususususdgsdyustgsfsyutsfdesf");
            return (0);
        }
    }
    console.println("cpu: ", this.cpuperf.cpu_load() * 100, "%, self: ", this.cpuperf.self_cpu_consumption() * 100, "%");
    sleep(0.05);
    return 0;
}

