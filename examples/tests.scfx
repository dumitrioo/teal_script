ctr(anything) {
    if(this.delay == undefined) {
        this.delay = 0.0007;
        this.tsfs = time();
        console.fixed();
        console.setprecision(16);
    }
    if(++this.i % 100 == 0) {
        ts = timestamp();
        tsfs = ts.fseconds();
        t = (0.1 - (tsfs - this.tsfs)) * 0.025;
        this.delay += sign(t) * t * t;
        this.tsfs = tsfs;
        if(this.i % 1000 == 0) {
            console.println(ts.as_iso_8601(), " ", this.delay);
        }
    }
    return this.delay;
}

