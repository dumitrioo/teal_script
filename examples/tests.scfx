function fact(n) {
    return n <= 1 ? n : n * fact(n - 1);
}

function mysin(x) {
    return x
        - pow(x, 3.0) / 6.0
        + pow(x, 5.0) / 120.0
        - pow(x, 7.0) / 5040.0
        + pow(x, 9.0) / 362880.0
        - pow(x, 11.0) / 39916800.0
        + pow(x, 13.0) / 6227020800.0
        - pow(x, 15.0) / 1307674368000.0
        + pow(x, 17.0) / 355687428096000.0
        - pow(x, 19.0) / 121645100408832000.0
        + pow(x, 21.0) / 51090942171709440000.0
        - pow(x, 23.0) / 25852016738884976640000.0
        + pow(x, 25.0) / 15511210043330985984000000.0;
}

sin_test() {
    console.setprecision(26);
    console.println(sin(1.0));
    console.println(mysin(1.0));
    return 0;
}

