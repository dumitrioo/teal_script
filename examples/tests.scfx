function num_to_suffixed(n, prec) {
    a = array("", "k", "M", "G", "T", "P", "E", "Z", "Y", "R", "Q");
    p = 0; k = n;
    while(k > 1000.0) {
        k /= 1000.0;
        ++p;
    }
    return array(ftoa(k, prec), a[p]);
}

my_test() {
    try {
        console.fixed();
        r = 6371239.0;
        solar_constant = 1360.8;
        s = M_PI * r * r;
        p = s * solar_constant;
        sunpower = num_to_suffixed(p, 18);
        console.setprecision(36);
        console.println(sunpower[0], " ", sunpower[1], "W");

        throw "exit";
    } catch(e) {
        console.error(e);
    }
    return 0;
}

