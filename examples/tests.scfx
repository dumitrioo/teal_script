untab(argv) {
    clargs = argv;
    clargs.pop_front();
    clargs.pop_front();
    for(i = 0; i < clargs.size(); ++i) {
        if(file_exists(clargs[i])) {
            try {
                console.println("processing file ", clargs[i]);
                save_to_file(clargs[i], clargs[i].load_from_file().replace_substr("\t", " " * 4));
            } catch(e) {
                console.error(e);
            }
        } else if (dir_exists(clargs[i])) {
            dir_list = list_directory(clargs[i], true);
            for(i = 0; i < dir_list.size(); ++i) {
                if(file_exists(dir_list[i])) {
                    try {
                        console.println("processing file ", dir_list[i]);
                        save_to_file(dir_list[i], dir_list[i].load_from_file().replace_substr("\t", " " * 4));
                    } catch(e) {
                        console.error(e);
                    }
                }
            }
        }
    }
}

// untab utb(command_line_args);


finddupes(argv) {
    clargs = argv;
    clargs.pop_front();
    clargs.pop_front();
    if(dir_exists(clargs[0])) {
        dupes = object();
        dir_list = list_directory(clargs[0], true);
        for(i = 0; i < dir_list.size(); ++i) {
            curr_fname = dir_list[i];
            if(file_exists(curr_fname)) {
                try dupes[sha256(load_from_file(curr_fname))].push_back(curr_fname); catch();
            }
        }
        for(i = 0; i < dupes.size(); ++i) {
            if(dupes[i].size() > 1) {
                for(j = 0; j < dupes[i].size(); ++j) {
                    console.println(dupes[i][j]);
                }
                console.println("----------------------------------------------------------");
            }
        }
    }
    return 0;
}

