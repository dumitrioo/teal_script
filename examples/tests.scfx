test_mat() {
    try {
        p = perspective(60, 1, 1, 50);
        l = look_at(0, 0, 0,  1, 0, 0,  0, 0, 1);

        for(i = 0.0; i < 60.0; i += 0.1) {
            point = vec4(i, 0, 0);
            v1 = p * l * point;
            console.println(point, "   ", v1);
        }
    } catch(e) {
        console.println("error ", e);
    }

    return 0;
}

