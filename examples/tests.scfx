function fibonacci(n, memo) {
    if(memo.contains(string(n)))
        return memo[string(n)];
    if(n <= 1)
        memo[string(n)] = n;
    else
        memo[string(n)] = fibonacci(n - 1, memo) + fibonacci(n - 2, memo);
    return memo[string(n)];
}

fib_test() {
    memo = object();
    println(fibonacci(12, memo));
    return 0;
}

