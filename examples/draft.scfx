// just for fun
// ...and simple tests

fn() {
    ab = array_buffer();

    ab.append(hton(i32(623)));
    ab.to_string().hexdump().println();

    ab.put_at(i32(623), 1);
    ab.to_string().hexdump().println();

    u = ab.u16_at(0);
    u = 0x1234;
    ab.to_string().hexdump().println();

    return exit(0);
}

fn main();
