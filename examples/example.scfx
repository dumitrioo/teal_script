        d = f.read(256);
        console.print(hexdump(d), '\n');
        console.print(hexdump(data_to_base85_str(d)), "\n");
        console.print(hexdump(data_to_base64_str(d)));
    } else {
        console.print("error opening file /dev/random");
        exit(-1);
    }
}

