example5() {
    if (!this.win_created) {
        this.win_created = true;
        this.sw = 1600;
        this.sh = 900;
        ray_init_window(this.sw, this.sh, "graphics");
        this.linestrip = array();
        this.pause = false;
        this.strip_color = Color(rand(), rand(), rand(), rand());
        this.tid = thread_id();
    }
    if (this.tid != thread_id()) {
        return this.tid;
    }
    if (ray_window_should_close()) {
        ray_close_window();
        exit(0);
    } else {
        if (ray_get_char_pressed() == 'p') {
            this.pause = !this.pause;
        }
        if (ray_get_key_pressed() == 300) {
            ray_toggle_full_screen();
        }
        ray_begin_drawing();
        ray_clear_background(Color(0, 0, 0, 255));
        i = 0;
        if (!this.pause) {
            for (; i < 50; ++i) {
                this.linestrip[i] = Vector2(rand() % this.sw, rand() % this.sh);
            }
            this.linestrip[i] = this.linestrip[0];
            this.strip_color = Color(rand(), rand(), rand(), rand());
        }
        ray_draw_line_strip(this.linestrip, this.strip_color);
        for (i = 0; i < this.linestrip.size() - 1; ++i) {
            clr = Color(rand(), rand(), rand(), rand());
            ray_draw_circle(this.linestrip[i].x(), this.linestrip[i].y(), rand() % 30, clr);
        }
        ray_end_drawing();
        sleep(0.01);
    }
    return this.tid;
}

