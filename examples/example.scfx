example2() {
    if (this.a == undefined) {
        this.rule = 30;
        // this.rule = 153;
        // this.rule = 106;
        // this.rule = 204; // identity
        // this.rule = 58;
        // this.rule = 225;
        // this.rule = 216;
        // this.rule = 210;
        // this.rule = 135;
        // this.rule = 75;
        // this.rule = 147;
        // this.rule = 45;
        // this.rule = 89;
        // this.rule = 105;
        // this.rule = 169;
        // this.rule = 54;
        // this.rule = 86;
        // this.rule = 150;
        // this.rule = 120;
        // this.rule = 232; // sharpen
        // this.rule = 240;
        this.a = array();
        for (i = 0; i < 64; ++i) {
            this.a[i] = (hwrand() & 1).u8();
        }
        this.c = 0;
    }
    CN = this.a.size();
    s = "";
    s.reserve(CN);
    for (i = 0; i < CN; ++i) {
        s += this.a[i] ? "." : " ";
    }
    console.print(s);
    a = array();
    a[0] = u8();
    for (i = 1; i <= CN; ++i) {
        indx = (this.a[i - 1] << 2) | (this.a[i % CN] << 1) | this.a[(i + 1) % CN];
        a[i % CN] = u8((this.rule >> indx) & 1);
    }
    this.a = a;
    return this.a;
}

