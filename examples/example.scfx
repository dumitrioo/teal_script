example1() {
    if (this.cur == undefined) {
        this.cur = rand();
        this.cycles = 0;
    }
    console.print(this.cur.utoa(2, 64).replace_substr("1", "*").replace_substr("0", " "));
    rule = 30;
    cur = 0;
    cur = cur.update_bit(0, rule.get_bit((this.cur.get_bit_field(0, 2) << 1) | this.cur.get_bit(63)));
    for (i = 1; i < 63; ++i) {
        cur = cur.update_bit(i, rule.get_bit(this.cur.get_bit_field(i - 1, 3)));
    }
    cur = cur.update_bit(63, rule.get_bit(this.cur.get_bit_field(62, 2) | (this.cur.get_bit(0) << 2)));
    this.cur = cur;
    return this.cur;
}

