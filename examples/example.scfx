example8() {
    earth_eq_r = 6378.1;
    earth_po_r = 6356.8;
    earth_r_ratio = earth_po_r / earth_eq_r;
    console.print("Earth's polar to equatorial radiuses ratio: ", earth_r_ratio);

    moon_eq_r = 1738.14;
    moon_po_r = 1735.97;
    moon_r_ratio = moon_po_r / moon_eq_r;
    console.print("Moon's polar to equatorial radiuses ratio: ", moon_r_ratio);
    console.print("---------------------");

    console.fixed();
    crust_width = 5.0 * 1000.0; // m
    outer_r = (1737.1) * 1000.0; // m
    inner_r = outer_r - crust_width; // m
    vol_factor = (M_PI * 4.0) / 3.0;
    whole_vol = vol_factor * pow(outer_r, 3.0);
    console.print("whole vol: ", whole_vol / 1000000000.0, " cubic km");
    inner_vol = vol_factor * pow(inner_r, 3.0);
    console.print("inner vol: ", inner_vol / 1000000000.0, " cubic km");
    crust_vol = whole_vol - inner_vol; // m^3
    console.print("crust vol: ", crust_vol / 1000000000.0, " cubic km");
    console.print("crust vol / whole vol = ", crust_vol / whole_vol);
    cr_dens_gcm3 = 4.540; // g / cm^3
    cr_dens_gm3 = 4.540 * pow(100.0, 3); // g / m^3
    cr_dens = cr_dens_gm3 / 1000.0; // kg / m^3
    console.print("crust density: ", cr_dens, " kg/m^3");
    crust_wt = crust_vol * cr_dens; // kg
    console.print("crust weight: ", crust_wt / 1000.0, " tonnes");
    crust_only_dens = crust_wt / whole_vol;
    console.print("crust only density: ", crust_only_dens);
    console.print("-----------------------------------------");
    return 0;
}

example8 ex8();


example7_1() {
    fname = temp_directory_path() + native_path_seperator() + "test_file_5898723489765";
    console.print("openinig file \"", fname, "\"");
    if ((f = file(fname, true, true)).ok()) {
        console.print("file: ", f.to_string());
        fs = f.size();
        console.print("file size: ", fs);
        console.print("file content:\n", hexdump(f.read(fs)));
        f.seekr(0);
        f.write("1231234\n");
        f.write("1231234\n");
        fs = f.size();
        console.print("file size: ", fs);
        f.seekr(0);
        console.print("file content:\n", hexdump(f.read(fs)));
        f.close();
        delete_filesystem_entry(fname);
    } else {
        console.print("file opening error");
    }
}

