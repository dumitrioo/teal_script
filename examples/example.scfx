example10() {
    v = vec4(1, 0, 0, 1);
    console.print("v: ", v);

    mr1 = rotation(deg2rad(60), 1, 1, 1);

    vr = mr1 * v;
    console.print("vr: ", vr);
    a = angle3d(vr, vec4(1, 1, 0, 1));
    console.print("angle: ", rad2deg(a));

    mr2 = rotation(a, 1, -1, 0);
    mr3 = rotation(deg2rad(-45), 0, 0, 1);
    console.print("mr1: ", mr1);
    console.print("mr2: ", mr2);
    console.print("mr3: ", mr3);
    v1 = mr3 * mr2 * mr1 * v;
    console.print("v1: ", v1);
}

