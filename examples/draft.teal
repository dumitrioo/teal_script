function array_avg(arr) {
    if(arr.is_array() && arr.size() > 0) {
        s = 0.0;
        for(i = 0; i < arr.size(); ++i) { s += (f64)arr[i]; }
        return s / arr.size();
    }
    return 0.0;
}

wind_speed_avg_fltr(curr_speed) { // filtering logic (recent 2 seconds average speed from input)
    if(this.vals == undefined) { this.vals = []; this.last_time = 0; this.avg_speed = 0.0; }
    if(steady_clock() - this.last_time > 0.2) {
        this.last_time = steady_clock();
        this.vals.push_back(curr_speed);
        if(this.vals.size() > 10) { this.vals.pop_front(); }
        this.avg_speed = this.vals.array_avg();
    }
    return this.avg_speed;
}

obstacle_distance_change_speed(dist) {
    t = steady_clock();
    if(this.prev_dist == undefined) {
        this.ds = 0.0;
    } else {
        this.ds = (dist - this.prev_dist) / (t - this.prev_time);
    }
    this.prev_dist = dist;
    this.prev_time = t;
    return this.ds;
}

critical_failure(pckg_ok, temp, bat) {
    if(!pckg_ok || temp > 90 || bat < 5) { this.res = true; }
    if(pckg_ok && temp < 50 && bat > 15) { this.res = false; }
    return this.res == undefined ? false : this.res;
}

return_to_base_logic(bat, g_breach, gps, rain) {
    if(bat < 20 || g_breach || gps < 30 || rain == 2) { this.res = true; }
    return this.res == undefined ? false : this.res;
}

hold_logic(op_ovr, obstcl_dist) {
    if(op_ovr || obstcl_dist < 2.0) { this.res = true; }
    return this.res == undefined ? false : this.res;
}

cautious_cruise_logic(wnd, rain, dst_dist) {
    return wnd > 10 || rain == 1 || dst_dist < 500;
}

normal_cruise_logic(bat, obstcl_dist, cautious, hold, ret_base, fail, para_deploy) {
    return !(para_deploy || cautious || hold || ret_base || fail) && bat > 50 && obstcl_dist > 50;
}

parashute_deployment(failure) {
    if(this.res == undefined) { this.res = false; }
    if(failure) { this.res = true; }
    return this.res;
}

speed_limit_logic(
    parashute_deploy,
    ret_to_base,
    hover,
    cautious,
    normal,
    wind,
    obst_dist_chng_speed
) {
    res = 0;
    if(parashute_deploy || hover) {
        res = 0;
    } else if(cautious) {
        res = 10 - wind;
        res = res < 3 ? 3 : res;
    } else if(ret_to_base) {
        res = 5;
    } else if(normal) {
        res = 15;
    }
    if(obst_dist_chng_speed < -50) {
        res = 0.5;
    }
    return res;
}

//---------------------------------------------------------------
// inputs
'battery_level'                battery_level;
'wind_speed'                   wind_speed;
'obstacle_distance'            obstacle_distance;
'rain_status'                  rain_status;
'gps_strength'                 gps_strength;
'package_integrity'            package_integrity;
'distance_to_destination'      distance_to_destination;
'motor_temperature'            motor_temperature;
'geofence_breach'              geofence_breach;
'operator_override'            operator_override;

// workers
obstacle_distance_change_speed obst_dist_chng_speed(obstacle_distance);
wind_speed_avg_fltr            wind_avg(wind_speed); // wind speed filter
critical_failure               fail(package_integrity, motor_temperature, battery_level);
parashute_deployment           deploy_para(fail);
return_to_base_logic           return_to_base(battery_level, geofence_breach, gps_strength, rain_status);
hold_logic                     hold(operator_override, obstacle_distance);
cautious_cruise_logic          cautious_cruise(wind_avg, rain_status, distance_to_destination);
normal_cruise_logic            normal_cruise(battery_level, obstacle_distance, cautious_cruise,
                                             hold, return_to_base, fail, deploy_para);

// output worker
speed_limit_logic              speed_limiter(deploy_para, return_to_base, hold, cautious_cruise,
                                             normal_cruise, wind_avg, obst_dist_chng_speed) 'speed_limit';
