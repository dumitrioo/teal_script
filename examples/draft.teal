function rnd_str(n) {
    cb = "0123456789qwertyuiopasdfghjklzx"
         "cvbnmQWERTYUIOPASDFGHJKLZXCVBNM"
         "~!@#$%^&+-*/()_=?`'\";:";
    cbs = cb.size();
    res = "";
    for (i = 0; i < n; ++i) {
        res += cb[rand() % cbs];
    }
    return res;
}

function undef_test() {
    println("undef_test()");
    return 0;
}

function sinus(x)
    return sin(x);

// adapted algo from Quake III Arena
function Q_rsqrt(x) {
    fx = (f64)x;
    i = 0x5fe6a09e667f3bcd - (fx.as_array_buffer().get_i64_at(0) >> 1);
    y = i.as_array_buffer().get_f64_at(0);
    x2 = fx * 0.5;
    y *= 1.5 - x2 * y * y;
    y *= 1.5 - x2 * y * y;
    y *= 1.5 - x2 * y * y;
    y *= 1.5 - x2 * y * y;
    return y;
}

function sqroot(x) {
    return 1 / Q_rsqrt(x);
}

function clamp(v, mi, ma) return v < mi ? mi : v > ma ? ma : v;

function integral(func, beg, end, dx) {
    s = 0.0;
    for(x = (f64)beg; x <= (f64)end; x += (f64)dx)
        s += func(x) * dx;
    return s;
}

function_test() {
    sin.integral(0, 1, 1e-4).println();
    M_PI.sin().println();
    return 0;
}

function k_predict(ks, u) {
    ks.x = ks.A * ks.x + ks.B * u;
    ks.P = ks.A * ks.P * ks.A + ks.Q;
}

function k_update(ks, z) {
    S = ks.H * ks.H * ks.P + ks.R;     // innovation covariance
    K = (ks.P * ks.H) / S;             // Kalman gain
    y = z - ks.H * ks.x;               // innovation
    ks.x = ks.x + K * y;
    ks.P = (1.0 - K * ks.H) * ks.P;
}

function apply_func(a, fn) {
    if(fn.typeof() != "func") { throw "not a function"; }
    if(a.is_array()) {
        for(i = 0; i < a.size(); ++i) {
            fn(a[i]);
        }
    } else {
        fn(a);
    }
}

function palindrom(s) {
    return
        s.size() < 2 ||
        s[0] == s[s.size() - 1] && palindrom(s.substr(1, s.size() - 2));
}

function fibonacci(n) {
    a = (float)0;
    b = (float)1;
    for(i = 0; i < n; ++i) {
        c = a + b;
        a = b;
        b = c;
    }
    return a;
}

function fibonaccir(n)
    if n <= 1
        return (float)n;
    else
        return fibonaccir((float)n - (float)1) + fibonaccir((float)n - (float)2);

function arr_vals_0_5(a) {
    a[0].println();
    a[5].println();
}

function obj_vals_c_f(o) {
    o["c"].println();
    o["f"].println();
}

function reverse(s) {
    return s.size() < 2 ? s : s.slice(1).reverse() + s[0];
}

function bitrev(n) {
    return atoi(itoa(n, 2).reverse(), 2);
}

function cpu_info() {
    res = object();
    if(PLATFORM == "linux") {
        cpu_strings = file("/proc/cpuinfo").read(1000000).split("\n");
        for(i = 0; i < cpu_strings.size(); ++i) {
            p = cpu_strings[i].split(":");
            if(p.size() == 2) {
                k = p[0].trim();
                if(res.key_exists(k)) { break; }
                v = p[1].trim();
                if(!["apicid", "core id", "initial apicid", "processor", "physical id"].contains(k)) {
                    if(["vmx flags", "bugs", "flags"].contains(k)) {
                        res[k] = v.trim().split(" ");
                    } else if(["cache_alignment", "clflush size", "cpu cores", "cpu family", "cpuid level", "model", "siblings", "stepping"].contains(k)) {
                        res[k] = v.trim().atoi();
                    } else if(["bogomips", "cpu MHz"].contains(k)) {
                        res[k] = v.trim().atof();
                    } else if(["microcode"].contains(k)) {
                        res[k] = v.trim().substr(2).atoi(16);
                    } else {
                        res[k] = v.trim();
                    }
                }
            }
        }
    }
    return res;
}

